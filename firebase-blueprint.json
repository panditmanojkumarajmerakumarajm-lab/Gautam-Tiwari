{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "balance": { "type": "number", "description": "Current wallet balance" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "balance"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Manual fund addition request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "utr": { "type": "string", "description": "12-digit Transaction ID" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "utr", "status", "timestamp"]
    },
    "Order": {
      "title": "Order",
      "description": "Service order placed by user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "link": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "link", "quantity", "price", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User public profiles and balances"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Admin-verifiable payment requests"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order history for users"
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "Admin access control list"
    }
  }
}
