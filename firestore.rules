rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check for GET/CREATE/UPDATE (exists is safe here)
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "shreemadbhagwat621@gmail.com" ||
        request.auth.token.email == "tiwarigautam819@gmail.com"
      ); 
    }

    // Admin check for LIST (exists is FORBIDDEN here for performance/stability)
    function isAdminListing() {
      return isSignedIn() && (
        request.auth.token.email == "shreemadbhagwat621@gmail.com" ||
        request.auth.token.email == "tiwarigautam819@gmail.com"
      );
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'balance', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.balance is number && data.balance >= 0 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().balance == 0;
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastLogin']) &&
                         incoming().balance == existing().balance) || isAdmin();
    }

    // --- Payment Validation ---
    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'amount', 'utr', 'status', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.utr is string && data.utr.size() >= 10 && data.utr.size() <= 64 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.timestamp == request.time;
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminListing());
      allow create: if isEmailVerified() && isValidPayment(incoming()) && isValidId(paymentId) && incoming().status == 'pending';
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status in ['approved', 'rejected'];
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'serviceId', 'link', 'quantity', 'price', 'status', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.serviceId is string &&
             data.link is string && data.link.size() <= 500 &&
             data.quantity is number && data.quantity > 0 &&
             data.price is number && data.price >= 0 &&
             data.status is string &&
             data.timestamp == request.time;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminListing());
      allow create: if isEmailVerified() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only manageable by existing admins or the hardcoded owner
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
